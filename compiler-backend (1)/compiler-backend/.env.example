# Copy this to .env and fill in your values
# Never commit .env to git!

# Get from https://console.anthropic.com (free tier available)
GEMINI_API_KEY=your-gemini-api-key-here

# Judge0 - use localhost:2358 when running via docker-compose
JUDGE0_URL=http://judge0-server:2358

# Redis - use localhost when running via docker-compose
REDIS_HOST=redis
REDIS_PORT=6379